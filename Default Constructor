// Default Constructor

// Write a Java program to create a class called “Cat” with instance variables name and age. Implement a default constructor that initializes the name to "Unknown" and the age to 0. Print the values of the variables.

// Sample Solution:

// Java Code:

// Cat.java

public class Cat {
    private String name;
    private int age;

    public Cat() {
        this.name = "Meow";
        this.age = 2;
    }

    public void setAge(int age) {
        if (age < 0) {
            System.out.println("Invalid age!");
            return;
        }
        this.age = age;
    }

    public int getAge() {
        return age;
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        if (name == null || name.isEmpty()) {
            System.out.println("Invalid name!");
            return;
        }
        this.name = name;
    }

    public static void main(String[] args) {
        Cat myCat = new Cat();
        System.out.println(myCat.getName());
        System.out.println(myCat.getAge());

        myCat.setName("Whiskers");
        myCat.setAge(5);

        System.out.println(myCat.getName());
        System.out.println(myCat.getAge());
    }
}
